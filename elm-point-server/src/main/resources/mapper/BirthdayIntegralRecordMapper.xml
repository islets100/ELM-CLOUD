<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="team.tjusw.elm.mapper.BirthdayIntegralRecordMapper">

    <!-- 结果映射 -->
    <resultMap id="BirthdayIntegralRecordResultMap" type="team.tjusw.elm.po.BirthdayIntegralRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="recordDate" column="record_date"/>
        <result property="monthlyEarned" column="monthly_earned"/>
        <result property="birthdayEarned" column="birthday_earned"/>
        <result property="monthlyPoints" column="monthly_points"/>
        <result property="birthdayPoints" column="birthday_points"/>
    </resultMap>

    <!-- 插入生日积分记录 -->
    <insert id="insert" parameterType="team.tjusw.elm.po.BirthdayIntegralRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO birthday_integral_records (user_id, record_date, monthly_earned, birthday_earned, monthly_points, birthday_points)
        VALUES (#{userId}, #{recordDate}, #{monthlyEarned}, #{birthdayEarned}, #{monthlyPoints}, #{birthdayPoints})
    </insert>

    <!-- 根据用户ID和记录日期查询 -->
    <select id="findByUserIdAndRecordDate" resultMap="BirthdayIntegralRecordResultMap">
        SELECT * FROM birthday_integral_records
        WHERE user_id = #{userId}
          AND record_date = #{recordDate}
    </select>

    <!-- 检查指定用户和日期的记录是否存在 -->
    <select id="existsByUserIdAndRecordDate" resultType="boolean">
        SELECT COUNT(*) > 0 FROM birthday_integral_records
        WHERE user_id = #{userId}
          AND record_date = #{recordDate}
    </select>

</mapper>
