<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="team.tjusw.elm.mapper.IntegralMapper">

    <!-- 结果映射 -->
    <resultMap id="IntegralResultMap" type="team.tjusw.elm.po.Integral">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="amount" column="amount"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="channel" column="channel"/>
        <result property="expireTime" column="expire_time"/>
        <result property="businessId" column="business_id"/>
        <result property="description" column="description"/>
        <result property="remainingAmount" column="remaining_amount"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 插入积分记录 -->
    <insert id="insert" parameterType="team.tjusw.elm.po.Integral" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO integral (user_id, amount, type, status, channel, expire_time, business_id, description, remaining_amount, create_time)
        VALUES (#{userId}, #{amount}, #{type}, #{status}, #{channel}, #{expireTime}, #{businessId}, #{description}, #{remainingAmount}, #{createTime})
    </insert>

    <!-- 根据ID更新积分记录 -->
    <update id="updateById" parameterType="team.tjusw.elm.po.Integral">
        UPDATE integral
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="remainingAmount != null">remaining_amount = #{remainingAmount},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询积分记录 -->
    <select id="selectById" parameterType="int" resultMap="IntegralResultMap">
        SELECT * FROM integral WHERE id = #{id}
    </select>

    <!-- 根据用户ID查询所有积分记录，按创建时间倒序 -->
    <select id="selectByUserIdOrderByCreateTimeDesc" parameterType="string" resultMap="IntegralResultMap">
        SELECT * FROM integral WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <!-- 根据用户ID和状态查询积分记录，按过期时间升序 -->
    <select id="selectByUserIdAndStatusOrderByExpireTimeAsc" resultMap="IntegralResultMap">
        SELECT * FROM integral
        WHERE user_id = #{userId} AND status = #{status}
        ORDER BY expire_time ASC
    </select>

    <!-- 根据用户ID、状态和过期时间查询积分记录 -->
    <select id="selectByUserIdAndStatusAndExpireTimeAfter" resultMap="IntegralResultMap">
        SELECT * FROM integral
        WHERE user_id = #{userId}
          AND status = #{status}
          AND expire_time > #{expireTime}
    </select>

    <!-- 查询过期的积分记录 -->
    <select id="selectByStatusAndExpireTimeBefore" resultMap="IntegralResultMap">
        SELECT * FROM integral
        WHERE status = #{status}
          AND expire_time &lt; #{expireTime}
    </select>

    <!-- 查询用户可用积分总和 -->
    <select id="sumAmountByUserIdAndStatusAndExpireTimeAfter" resultType="int">
        SELECT SUM(amount) FROM integral
        WHERE user_id = #{userId}
          AND status = #{status}
          AND expire_time > #{expireTime}
    </select>

</mapper>
